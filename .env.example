# Mnemo Server — Environment Configuration
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection (must have pgvector extension)
MNEMO_DATABASE_URL=postgresql://mnemo:CHANGE_ME@localhost:5432/mnemo

# Admin key for platform management (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
MNEMO_ADMIN_KEY=

# ── Docker ────────────────────────────────────────────────────────────────────

# Database URL as seen from inside the Docker container
MNEMO_DOCKER_DATABASE_URL=postgresql://mnemo:CHANGE_ME@host.docker.internal:5432/mnemo

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key — enables LLM decomposer (Haiku). Without it, falls back to regex.
ANTHROPIC_API_KEY=

# Hugging Face token — required if embedding model is gated
HF_TOKEN=

# Test database (for running pytest)
MNEMO_TEST_DATABASE_URL=postgresql://mnemo:CHANGE_ME@localhost:5432/mnemo_test

# Embedding model (defaults shown)
# MNEMO_EMBEDDING_MODEL=google/embeddinggemma-300m
# MNEMO_EMBEDDING_DIM=768
